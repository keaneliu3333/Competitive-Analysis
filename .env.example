# Copy this file to .env.local for local/internal MVP use.
# Do not put real secrets in this example file.

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini

# Optional cost estimates, USD per 1M tokens.
# Use either input/output pricing or total-token pricing.
OPENAI_INPUT_USD_PER_1M=
OPENAI_OUTPUT_USD_PER_1M=
OPENAI_TOTAL_USD_PER_1M=

# Internal access control.
# APP_ACCESS_TOKEN is the legacy read/write token.
# Prefer APP_READ_TOKEN + APP_WRITE_TOKEN when sharing with reviewers.
APP_ACCESS_TOKEN=
APP_READ_TOKEN=
APP_WRITE_TOKEN=

# Local server.
PORT=4173
