# Copy this file to .env.local for local/internal MVP use.
# Do not put real secrets in this example file.

# Local server.
HOST=127.0.0.1
PORT=4173

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
# Optional: use an OpenAI-compatible gateway/proxy when api.openai.com is not reachable.
OPENAI_BASE_URL=https://api.openai.com/v1
AI_REQUEST_TIMEOUT_MS=60000
# Optional local HTTP proxy for AI API calls. Keep OPENAI_BASE_URL as the API endpoint.
HTTPS_PROXY=

# Multi-model routing.
# DeepSeek is the default provider for text analysis and comparison.
# Qwen-VL is the default vision provider for uploaded detail images and URL image candidates.
AI_PROVIDER=deepseek
COMPARE_AI_PROVIDER=deepseek
VISION_PROVIDER=qwen
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
QWEN_API_KEY=
QWEN_MODEL=qwen-vl-max
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_REQUEST_TIMEOUT_MS=60000

# Optional URL detail-page image ingestion limits.
# These prevent tiny logos/tracking images or oversized images from being sent to the vision model.
AUTO_SOURCE_IMAGE_COUNT=4
AUTO_SOURCE_IMAGE_BYTES=2621440
AUTO_SOURCE_IMAGE_DATA_URL_CHARS=3000000
AUTO_SOURCE_IMAGE_MIN_WIDTH=640
AUTO_SOURCE_IMAGE_MIN_SHORT_EDGE=320
AUTO_SOURCE_IMAGE_MIN_PIXELS=250000

# Optional browser-assisted detail-page screenshot capture.
# Launch order is: Google Chrome -> Microsoft Edge -> Playwright Chromium.
# Use this only when Chrome/Edge is installed in a non-standard location.
# macOS example: /Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge
# Windows example: C:\Program Files\Microsoft\Edge\Application\msedge.exe
BROWSER_EXECUTABLE_PATH=
BROWSER_FETCH_PROFILE_DIR=
# Keep sandbox enabled by default. Set to 1 only if a specific Windows/Linux machine cannot launch Chromium.
BROWSER_FETCH_DISABLE_SANDBOX=0
BROWSER_FETCH_SCREENSHOT_WIDTH=1365
BROWSER_FETCH_SCREENSHOT_HEIGHT=1100
BROWSER_FETCH_SCREENSHOT_COUNT=24
BROWSER_FETCH_SCREENSHOT_MAX_SCROLL_HEIGHT=30000

# Optional cost estimates, USD per 1M tokens.
# Use either input/output pricing or total-token pricing.
OPENAI_INPUT_USD_PER_1M=
OPENAI_OUTPUT_USD_PER_1M=
OPENAI_TOTAL_USD_PER_1M=

# Internal access control.
# APP_ACCESS_TOKEN is the legacy read/write token.
# Prefer APP_READ_TOKEN + APP_WRITE_TOKEN when sharing with reviewers.
APP_ACCESS_TOKEN=
APP_READ_TOKEN=
APP_WRITE_TOKEN=

# Local server.
