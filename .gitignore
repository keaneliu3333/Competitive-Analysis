.venv-packages/
.venv/
venv/
__pycache__/
*.py[cod]

# Logs, coverage, and generated reports
*.log
coverage/
.nyc_output/
reports/
.tmp/

# Runtime state
data/workbench-state.json
data/api-usage.json
data/*.json
